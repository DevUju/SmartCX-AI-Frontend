@tailwind utilities;

:root {
	--bg-paper: #f2efe8;
	--ink: #171717;
	--ink-soft: #5a5a5a;
	--card: #ffffff;
	--line: #ddd9cf;
	--accent: #111111;
	--ok: #27724a;
}

* {
	box-sizing: border-box;
}

html,
body {
	margin: 0;
	min-height: 100%;
}

body {
	font-family: 'Archivo', sans-serif;
	color: var(--ink);
	background:
		radial-gradient(circle at 15% 10%, #e6ddcd 0%, transparent 36%),
		radial-gradient(circle at 85% 85%, #dfd4c4 0%, transparent 34%),
		var(--bg-paper);
}

h1,
h2,
h3 {
	font-family: 'Space Grotesk', sans-serif;
	letter-spacing: -0.02em;
}

a {
	color: inherit;
}

.auth-shell {
	min-height: 100vh;
	padding: 2rem 1rem;
	display: flex;
	align-items: center;
	justify-content: center;
}

.auth-link {
	text-decoration: underline;
	text-underline-offset: 4px;
	font-weight: 600;
}

.field {
	display: flex;
	flex-direction: column;
	gap: 0.4rem;
}

.field label {
	font-size: 0.86rem;
	color: var(--ink-soft);
	font-weight: 600;
}

.field input,
.field select,
.field textarea {
	width: 100%;
	border: 1px solid var(--line);
	border-radius: 0.8rem;
	padding: 0.8rem 0.92rem;
	background: #fff;
	font: inherit;
}

.field input:focus,
.field select:focus,
.field textarea:focus {
	outline: 2px solid #1f1f1f;
	outline-offset: 1px;
}

.btn-primary {
	border: 0;
	border-radius: 0.8rem;
	background: #121212;
	color: #fff;
	font-family: 'Space Grotesk', sans-serif;
	letter-spacing: 0.03em;
	padding: 0.9rem 1.1rem;
	cursor: pointer;
}

.btn-primary:disabled {
	opacity: 0.65;
	cursor: default;
}

.error-text {
	color: #ab2b2b;
	font-size: 0.8rem;
}

.footer-copy {
	font-size: 0.75rem;
	color: var(--ink-soft);
	text-align: center;
}
