@use '@angular/material' as mat;
@use 'sass:map';

// Define custom color palettes
$smartcx-primary: (
  0: #000000,
  10: #0d47a1,
  20: #1565c0,
  25: #1a73e8,
  30: #1976d2,
  35: #1e88e5,
  40: #2196f3,
  50: #42a5f5,
  60: #64b5f6,
  70: #90caf9,
  80: #bbdefb,
  90: #e3f2fd,
  95: #f3f8ff,
  99: #fafbff,
  100: #ffffff,
);

$smartcx-secondary: (
  0: #000000,
  10: #1a1a1a,
  20: #2d2d2d,
  25: #3a3a3a,
  30: #464646,
  35: #525252,
  40: #5e5e5e,
  50: #787878,
  60: #919191,
  70: #ababab,
  80: #c5c5c5,
  90: #e0e0e0,
  95: #eeeeee,
  99: #fafafa,
  100: #ffffff,
);

$smartcx-tertiary: (
  0: #000000,
  10: #3d2817,
  20: #5d4037,
  25: #6d4c41,
  30: #795548,
  35: #8d6e63,
  40: #a1887f,
  50: #bcaaa4,
  60: #d7ccc8,
  70: #efebe9,
  80: #f5f5f5,
  90: #fafafa,
  95: #fcfbfa,
  99: #fffbfe,
  100: #ffffff,
);

// Define Material 3 theme at global level
html {
  height: 100%;

  @include mat.theme((
    color: (
      primary: $smartcx-primary,
      secondary: $smartcx-secondary,
      tertiary: $smartcx-tertiary,
    ),
    typography: Roboto,
    density: 0,
  ));
}

body {
  color-scheme: light;
  background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
  background-attachment: fixed;
  color: var(--mat-sys-on-surface);
  font: var(--mat-sys-body-medium);
  margin: 0;
  min-height: 100vh;
}

// Material component overrides
.mat-mdc-form-field {
  width: 100%;

  .mat-mdc-text-field-wrapper {
    padding-bottom: 0.5rem;
  }
}

.mat-mdc-raised-button {
  &:not([disabled]) {
    background: linear-gradient(135deg, #1976d2 0%, #1565c0 100%);
    color: white;
    box-shadow: 0 4px 8px rgba(25, 118, 210, 0.3);

    &:hover {
      box-shadow: 0 6px 12px rgba(25, 118, 210, 0.4);
    }
  }
}

.mat-mdc-button {
  color: #1976d2;

  &:hover {
    background: rgba(25, 118, 210, 0.08);
  }
}

.mat-mdc-icon-button {
  color: #666;

  &:hover {
    color: #1976d2;
  }
}

// Material Card styling
.mat-mdc-card {
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  border: 1px solid rgba(0, 0, 0, 0.05);
  overflow: hidden;

  &:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }
}

// Material Progress Bar
.mat-mdc-progress-bar {
  height: 8px;
  border-radius: 4px;

  .mat-mdc-progress-bar-fill::after {
    background: linear-gradient(90deg, #1976d2 0%, #42a5f5 100%);
  }
}

// Material Checkbox
.mat-mdc-checkbox {
  .mdc-checkbox__native-control:checked ~ .mdc-checkbox__background {
    background: #1976d2;
  }
}
