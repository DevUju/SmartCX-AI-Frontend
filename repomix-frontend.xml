      <p>{{ customerEmail() }}</p>
      <p>{{ customerPhone() }}</p>
      <p>Location: {{ customerLocation() }}</p>
    </article>

    <article class="card">
      <h2>Order Summary</h2>
      <p>Issue ID: {{ ticket()?.issueId || '--' }}</p>
      <p>Items: 2</p>
      <p>Total: N {{ customerTotalSpent() ?? '--' }}</p>
      <button type="button" class="btn-lite">View Logistics</button>
    </article>
  </aside>

  <main class="center-col">
    @if (errorMessage()) {
    <article class="ai-card">
      <p>{{ errorMessage() }}</p>
      <button type="button" class="btn-primary" (click)="retry()">Retry</button>
    </article>
    }

    <article class="ai-card">
      <h2 style="display: flex; align-items: center; gap: 0.5rem;">
        <span style="font-size: 1.2rem;">✨</span> AI Resolution Summary
      </h2>
      <p>{{ ticket()?.resolutionSummary || 'No resolution summary recorded.' }}</p>
    </article>

    <article class="chat-card">
      @for (message of messages(); track message) {

      <div class="msg" [class.customer]="message.sender === 'customer'" [class.agent]="message.sender === 'agent'"
        [class.note]="message.sender === 'note'">
        {{ message.text }}
      </div>
      }
      @if (ticket()?.status !== 'resolved') {
      <div class="reply-tabs">
        <button type="button" [class.active]="activeTab() === 'reply'" (click)="setTab('reply')">Reply</button>
        <button type="button" [class.active]="activeTab() === 'note'" (click)="setTab('note')">Internal Note</button>
      </div>

      <div class="composer">
        @if (activeTab() === 'note') {
        <p class="note-hint" style="grid-column: 1 / -1;">This note is private — only agents can see it.</p>
        }
        <input type="text" [placeholder]="activeTab() === 'note' ? 'Add an internal note...' : 'Type message...'"
