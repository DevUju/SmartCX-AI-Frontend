        style="background: transparent; border: none; cursor: pointer; color: var(--ink-soft); font-weight: bold;">✕</button>
    </div>
    @for (reply of smartReplies(); track reply) {
    <button type="button" class="suggestion-chip" (click)="useSuggestedReply(reply)">
      {{ reply }}
    </button>
    }
  </div>
  }


  <button type="button" (click)="toggleHistory()" class="btn-lite">
    {{ showHistory() ? 'Hide History' : 'Full History' }}
  </button>

  @if (showHistory()) {
  <div class="history-panel">
    <h3>Ticket History</h3>
    @if (loadingHistory()) {
    <p>Loading...</p>
    } @else if (history().length === 0) {
    <p>No history recorded yet.</p>
    } @else {
    @for (entry of history(); track entry.id) {
    <div class="history-entry">
      <span class="history-action">{{ formatAction(entry.action) }}</span>
      <span class="history-actor">by {{ entry.actorName }}</span>
      <span class="history-time">{{ entry.createdAt | date:'short' }}</span>
