<div class="container">
  <div class="projects-container">
  <!-- Header -->
  <div class="header-row">
    <h2 class="header">Focus</h2>
    <button mat-icon-button class="settings-btn" routerLink="/profile">
      <mat-icon>settings</mat-icon>
    </button>
  </div>

  <div *ngIf="error()" class="error-message">{{ error() }}</div>

  <!-- Overview -->
  <div class="section overview">
    <h3>Projects</h3>
    <p class="overview-text">
      Manage your focused workspaces and track progress across your primary life domains.
    </p>
  </div>

  <!-- Project Cards -->
  <p *ngIf="!projects().length" class="overview-text">No active projects yet.</p>
  <div *ngFor="let project of projects()" class="project-card">
    <h4>{{ project.name }}</h4>
    <p class="subtext">{{ project.description || 'No description' }}</p>
    <p class="progress-text">{{ project.progress || 0 }}% complete</p>
    <mat-progress-bar mode="determinate" [value]="project.progress || 0"></mat-progress-bar>
    <button mat-button color="warn" (click)="deleteProject(project.id)">Delete</button>
  </div>

  <!-- Add New Project -->
  <div class="add-project">
    <button mat-stroked-button color="primary" (click)="addProject()">Add New Project</button>
    <p class="add-text">Define a new focus domain</p>
  </div>

  <!-- Global Progress -->
  <div class="section global-progress">
    <h3>Global Progress</h3>
    <div class="progress-box">
      <p class="progress-title">Focused Week</p>
      <p class="progress-value">{{ getGlobalProgress() }}%</p>
      <p class="progress-note">Based on active projects</p>
    </div>
  </div>

  <!-- Archived & Folders -->
  <div class="section archived">
    <h3>Archived & Folders</h3>
